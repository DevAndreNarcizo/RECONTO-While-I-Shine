; Engine configuration file.
; RECONTO: Enquanto Eu Brilhar — projeto Godot 4.x
config_version=5

[application]

config/name="RECONTO"
config/description="RECONTO: Enquanto Eu Brilhar — bullet heaven de folclore brasileiro. Você é uma lenda defendendo a mata da Corrupção."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
GameState="*res://scripts/autoload/game_state.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
EnemySpawner="*res://scripts/autoload/enemy_spawner.gd"
MoonCycleManager="*res://scripts/autoload/moon_cycle_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

